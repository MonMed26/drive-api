# Server
PORT=3000

# API Key Secret (used for hashing API keys)
API_KEY_SECRET=your-api-key-secret-here

# Signed URL Secret (used for generating signed CDN URLs)
SIGNED_URL_SECRET=your-signed-url-secret-here

# Signed URL Expiry in seconds (default: 1 hour)
SIGNED_URL_EXPIRY=3600

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/accounts/oauth/callback

# Database
DATABASE_URL=file:./dev.db
